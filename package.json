{
  "name": "@bw/root",
  "private": true,
  "license": "MIT",
  "workspaces": {
    "packages": [
      "packages/*",
      "scripts/"
    ],
    "catalog": {},
    "catalogs": {}
  },
  "scripts": {
    "bw": "bw run -N -W bw --script=",
    "bw:test": "bw run -o plain test bw --",
    "bw:lint": "bw run -o plain lint bw --",
    "bw:build": "bw run -o plain build bw --",
    "bw:build:test": "bw run -o plain build:test bw --",
    "mcp-server": "bw mcp-server",
    "docs": "bw run -N -W docs",
    "docs:lint": "bw run -o plain lint doc-website --",
    "docs:dev": "bw run -o plain dev doc-website --",
    "docs:build": "bw run -o plain build doc-website --",
    "docs:build:dev": "bw run -o plain build:dev doc-website --",
    "docs:preview": "bw run -o plain preview doc-website --",
    "sandbox": "bw run -o plain -W sandbox",
    "sandbox:cli:local": "bun --cwd=./packages/sandbox run cli:local",
    "sandbox:cli:release": "bun --cwd=./packages/sandbox run cli:release",
    "sandbox:api:local": "bw run api:local sandbox -o plain --",
    "sandbox:api:release": "bw run api:release sandbox -o plain --",
    "lint": "bw run lint -P --",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "type-check": "bw run type-check -P --",
    "generate-cursor-rules": "bw run generate-cursor-rules scripts -o plain --",
    "generate-readme": "bw run generate-readme scripts -o plain --",
    "prepare": "cd packages/bun-workspaces && bun run generate-modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "^1.3.5",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "bun-workspaces": "workspace:*",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "json-schema-to-ts": "^3.1.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css,md,mdx,yaml,yml}": "prettier --write"
  }
}
