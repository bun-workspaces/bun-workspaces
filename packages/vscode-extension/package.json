{
  "name": "bun-workspaces-vscode",
  "displayName": "Bun Workspaces",
  "description": "Manage Bun monorepo workspaces from VS Code and Cursor",
  "version": "0.0.1",
  "private": true,
  "publisher": "bun-workspaces",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:bun.lock"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "bunWorkspaces.workspacesView",
          "name": "bun-workspaces",
          "when": "bunWorkspaces.active"
        }
      ]
    },
    "commands": [
      {
        "command": "bunWorkspaces.refreshWorkspaces",
        "title": "Refresh Project",
        "category": "bun-workspaces",
        "icon": "$(refresh)"
      },
      {
        "command": "bunWorkspaces.runScript",
        "title": "Run Script",
        "category": "Bun Workspaces"
      }
    ],
    "configuration": {
      "title": "Bun Workspaces",
      "properties": {
        "bunWorkspaces.bunPath": {
          "type": "string",
          "default": "",
          "description": "Path to the bun binary. Leave empty to auto-detect from common locations."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "bunWorkspaces.refreshWorkspaces",
          "when": "view == bunWorkspaces.workspacesView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "init-dev-project": "echo '[Dev Project] Initializing...' && cd devProject && bun --silent install && echo '[Dev Project] Initialized.'",
    "dev": "bun run scripts/dev.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "vscode": "^1.1.37"
  }
}
